# Supabase (cloud mirror — the app runs fully offline without these)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Calendar (Phase 5 — client-side OAuth, only a public client id needed;
# setup steps in docs/google-setup.md)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# RLS test harness only (supabase/tests/rls-check.mjs) — two throwaway test users
RLS_TEST_EMAIL_A=
RLS_TEST_PASSWORD_A=
RLS_TEST_EMAIL_B=
RLS_TEST_PASSWORD_B=
